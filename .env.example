# BẮT BUỘC - dùng đúng cùng giá trị với bản Production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FLASK_SECRET_KEY=change-this-to-a-long-random-secret

# TÙY CHỌN - app vẫn chạy nếu không khai báo
APP_ENV=production

# CHẾ ĐỘ TEST AN TOÀN — chỉ bật khi SUPABASE_URL trỏ sang project Supabase TEST riêng
# APP_ENV=test
# PES_ARENA_TEST_MODE=true
# DATABASE_SAFETY_TOKEN=PES_ARENA_TEST_DATABASE

# Tên tương thích cũ, không cần tạo nếu đã có các biến chính ở trên:
# SUPABASE_KEY=your-service-role-key
# SECRET_KEY=change-this-to-a-long-random-secret

# Chỉ cho phép mật khẩu 1 ký tự khi Test Mode đã được xác nhận an toàn ở trên.
# Tuyệt đối không bật trên Production.
# ALLOW_SIMPLE_TEST_PASSWORDS=true
